{
  "name": "inspection-platform-manu",
  "version": "0.1.0",
  "private": true,
  "description": "巡检宝无人机巡检管理平台",
  "scripts": {
    "dev:admin": "pnpm --filter @xunjianbao/admin-web dev",
    "dev:api": "pnpm --filter @xunjianbao/api dev",
    "start:api": "pnpm --filter @xunjianbao/api start",
    "build": "pnpm -r build",
    "build:admin": "pnpm --filter @xunjianbao/admin-web build",
    "build:api": "pnpm --filter @xunjianbao/api build",
    "db:generate": "pnpm --filter @xunjianbao/api db:generate",
    "db:push": "pnpm --filter @xunjianbao/api db:push",
    "db:seed": "pnpm --filter @xunjianbao/api db:seed",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@11.7.0"
}
